{item.value} predios</p>\n        </div>\n      );\n    }\n    return null;\n  };\n\n  const renderLegend = (props) => {\n    const { payload } = props;\n    return (\n      <ul className=\"flex flex-wrap justify-center gap-3 mt-2\">\n        {payload.map((entry, index) => (\n          <li key={`legend-${index}`} className=\"flex items-center gap-1.5 text-xs\">\n            <span\n              className=\"w-2.5 h-2.5 rounded-full\"\n              style={{ backgroundColor: entry.color }}\n            />\n            <span className=\"text-gray-600\">{entry.value}</span>\n          </li>\n        ))}\n      </ul>\n    );\n  };\n\n  return (\n    <ResponsiveContainer width=\"100%\" height=\"100%\">\n      <PieChart>\n        <Pie\n          data={data}\n          cx=\"50%\"\n          cy=\"45%\"\n          innerRadius={45}\n          outerRadius={70}\n          paddingAngle={2}\n          dataKey=\"value\"\n          animationBegin={0}\n          animationDuration={800}\n        >\n          {data.map((entry, index) => (\n            <Cell key={`cell-${index}`} fill={entry.color} />\n          ))}\n        </Pie>\n        <Tooltip content={<CustomTooltip />} />\n        <Legend content={renderLegend} />\n      </PieChart>\n    </ResponsiveContainer>\n  );\n}\n\nexport default StatusPieChart;\n","usedDeprecatedRules":[]},{"filePath":"/home/acbel/Documentos/Desarrollo/SO_Solutions/Aquanova-FrontEnd/Aquanova/src/components/Home/hooks/useMapData.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/acbel/Documentos/Desarrollo/SO_Solutions/Aquanova-FrontEnd/Aquanova/src/components/Home/hooks/useMetrics.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/acbel/Documentos/Desarrollo/SO_Solutions/Aquanova-FrontEnd/Aq